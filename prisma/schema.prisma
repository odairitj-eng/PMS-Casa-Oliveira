generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id                   String               @id @default(uuid())
  name                 String
  basePrice            Float
  cleaningFee          Float                @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  bathrooms            Int                  @default(2)
  bedrooms             Int                  @default(2)
  beds                 Int                  @default(3)
  city                 String?
  country              String?
  currency             String               @default("BRL")
  fullDescription      String?
  hostName             String?
  isActive             Boolean              @default(true)
  latitude             Float?
  locationText         String?
  longitude            Float?
  maxGuests            Int                  @default(4)
  minimumNights        Int                  @default(2)
  neighborhood         String?
  propertyType         String?              @default("HOUSE")
  publicSubtitle       String?
  publicTitle          String?
  shortDescription     String?
  state                String?
  allowsPets           Boolean              @default(false)
  maxPets              Int                  @default(0)
  postalCode           String?
  publicLatitude       Float?
  publicLongitude      Float?
  street               String?
  streetNumber         String?
  slug                 String               @unique @default("")
  channexId            String?              @unique
  accommodationType    String?              @default("Espaço inteiro")
  buildingFloors       Int?                 @default(1)
  category             String?              @default("Casa")
  constructionYear     Int?
  floorNumber          Int?                 @default(0)
  propertySize         Float?
  propertySizeUnit     String?              @default("m²")
  checkInEnd           String?              @default("22:00")
  checkInStart         String?              @default("14:00")
  checkOutEnd          String?              @default("11:00")
  cancellationPolicyId String?
  wifiName             String?
  wifiPassword         String?
  availabilityWindows  AvailabilityWindow[]
  blockedDates         BlockedDate[]
  integrations         Integration[]
  messageTemplates     MessageTemplate[]
  nightlyOverrides     NightlyOverride[]
  pricingRules         PricingRule[]
  cancellationPolicy   CancellationPolicy?  @relation(fields: [cancellationPolicyId], references: [id])
  amenities            PropertyAmenity[]
  guide                PropertyGuide?
  photos               PropertyPhoto[]
  rules                PropertyRule[]
  reservations         Reservation[]
  reservationLinks     ReservationLink[]
  syncLogs             SyncLog[]
}

model Guest {
  id                    String              @id @default(uuid())
  name                  String
  email                 String              @unique
  phone                 String
  isVip                 Boolean             @default(false)
  notes                 String?
  totalBookings         Int                 @default(0)
  createdAt             DateTime            @default(now())
  userId                String?             @unique
  completedStays        Int                 @default(0)
  isFiveStar            Boolean             @default(false)
  lastReservationAt     DateTime?
  lastStayAt            DateTime?
  sourceChannel         String?             @default("DIRECT")
  status                String              @default("REGULAR")
  totalRevenueGenerated Float               @default(0)
  updatedAt             DateTime            @default(now()) @updatedAt
  user                  User?               @relation(fields: [userId], references: [id])
  messageLogs           MessageLog[]
  reservations          Reservation[]
  credits               ReservationCredit[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  accounts      Account[]
  guest         Guest?
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Reservation {
  id               String                @id @default(uuid())
  propertyId       String
  guestId          String
  checkIn          DateTime
  checkOut         DateTime
  status           ReservationStatus     @default(PENDING_PAYMENT)
  totalAmount      Float
  nightlyRate      Float
  cleaningFee      Float
  totalNights      Int
  holdExpiresAt    DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  numGuests        Int?                  @default(1)
  accessToken      String                @unique @default(uuid())
  rebookedFromId   String?               @unique
  blockedDates     BlockedDate[]
  messageLogs      MessageLog[]
  payments         Payment[]
  guest            Guest                 @relation(fields: [guestId], references: [id])
  property         Property              @relation(fields: [propertyId], references: [id])
  rebookedFrom     Reservation?          @relation("RebookingHistory", fields: [rebookedFromId], references: [id])
  rebookedTo       Reservation?          @relation("RebookingHistory")
  creditsGenerated ReservationCredit[]
  events           ReservationEvent[]
  occupants        ReservationOccupant[]
  replacementRef   ReservationRebooking? @relation("NewReservation")
  rebookingHistory ReservationRebooking? @relation("OriginalReservation")

  @@index([propertyId])
  @@index([guestId])
}

model CancellationPolicy {
  id                      String     @id @default(uuid())
  name                    String
  description             String?
  cancelFreeLimitHours    Int        @default(48)
  partialRefundPercentage Float      @default(50)
  nonRefundableLimitHours Int        @default(24)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  properties              Property[]
}

model ReservationEvent {
  id            String      @id @default(uuid())
  reservationId String
  type          String
  userId        String?
  reason        String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model ReservationOccupant {
  id            String      @id @default(uuid())
  reservationId String
  name          String
  document      String?
  isChild       Boolean     @default(false)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model ReservationCredit {
  id                  String       @id @default(uuid())
  guestId             String
  propertyId          String?
  sourceReservationId String?
  amountOriginal      Float
  amountAvailable     Float
  amountUsed          Float        @default(0)
  currency            String       @default("BRL")
  code                String       @unique
  reason              String?
  status              CreditStatus @default(ACTIVE)
  expiresAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  guest               Guest        @relation(fields: [guestId], references: [id])
  sourceReservation   Reservation? @relation(fields: [sourceReservationId], references: [id])

  @@index([guestId])
  @@index([code])
}

model ReservationRebooking {
  id                      String      @id @default(uuid())
  originalReservationId   String      @unique
  newReservationId        String      @unique
  creditUsedAmount        Float       @default(0)
  additionalPaymentAmount Float       @default(0)
  reason                  String?
  createdBy               String?
  createdAt               DateTime    @default(now())
  newReservation          Reservation @relation("NewReservation", fields: [newReservationId], references: [id])
  originalReservation     Reservation @relation("OriginalReservation", fields: [originalReservationId], references: [id])
}

model Payment {
  id                   String        @id @default(uuid())
  reservationId        String
  gatewayTransactionId String?
  method               PaymentMethod
  status               PaymentStatus @default(PENDING)
  amount               Float
  createdAt            DateTime      @default(now())
  expiresAt            DateTime?
  externalId           String?
  provider             String?
  updatedAt            DateTime      @default(now()) @updatedAt
  refundAmount         Float?
  refundProviderId     String?
  refundStatus         String?
  refundedAt           DateTime?
  reservation          Reservation   @relation(fields: [reservationId], references: [id])
}

model BlockedDate {
  id            String        @id @default(uuid())
  propertyId    String
  date          DateTime
  source        BlockedSource
  reservationId String?
  createdAt     DateTime      @default(now())
  reason        String?
  property      Property      @relation(fields: [propertyId], references: [id])
  reservation   Reservation?  @relation(fields: [reservationId], references: [id])

  @@unique([propertyId, date])
  @@index([propertyId])
}

model AvailabilityWindow {
  id          String     @id @default(uuid())
  propertyId  String
  startDate   DateTime
  endDate     DateTime
  mode        WindowMode @default(MANUAL_RANGE)
  rollingDays Int?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  property    Property   @relation(fields: [propertyId], references: [id])

  @@index([propertyId, startDate, endDate])
}

model NightlyOverride {
  id            String   @id @default(uuid())
  propertyId    String
  date          DateTime
  price         Float
  minimumNights Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  property      Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date])
  @@index([propertyId])
}

model PricingRule {
  id          String    @id @default(uuid())
  propertyId  String
  type        RuleType
  value       Float
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  endDate     DateTime?
  minDays     Int?
  startDate   DateTime?
  color       String?
  property    Property  @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model Integration {
  id         String    @id @default(uuid())
  platform   Platform
  icalUrl    String
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model SyncLog {
  id           String     @id @default(uuid())
  platform     Platform
  status       SyncStatus
  eventsAdded  Int        @default(0)
  errorMessage String?
  createdAt    DateTime   @default(now())
  propertyId   String?
  property     Property?  @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model SystemSettings {
  id                     String   @id @default("singleton")
  propertyId             String?
  mercadoPagoPublicKey   String?
  mercadoPagoAccessToken String?
  whatsappNumber         String?
  contactEmail           String?
  minNightsDefault       Int      @default(2)
  maxGuestsDefault       Int      @default(4)
  updatedAt              DateTime @updatedAt
}

model ReservationLink {
  id             String    @id @default(uuid())
  token          String    @unique
  discount       Float?
  expiresAt      DateTime?
  preFilledDates String?
  createdAt      DateTime  @default(now())
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id])
}

model PropertyPhoto {
  id         String   @id @default(uuid())
  propertyId String
  imageUrl   String
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyAmenity {
  id          String   @id @default(uuid())
  propertyId  String
  amenityKey  String
  amenityName String
  iconName    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityKey])
  @@index([propertyId])
}

model PropertyRule {
  id         String   @id @default(uuid())
  propertyId String
  ruleText   String
  iconName   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model ProcessedEvent {
  id        String   @id
  provider  String
  createdAt DateTime @default(now())

  @@index([id, provider])
}

model PropertyGuide {
  id          String         @id @default(uuid())
  propertyId  String         @unique
  isActive    Boolean        @default(true)
  accentColor String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  places      GuidePlace[]
  sections    GuideSection[]
  property    Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model GuideSection {
  id        String        @id @default(uuid())
  guideId   String
  type      SectionType
  title     String
  content   String?
  imageUrl  String?
  iconName  String?
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  config    Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  guide     PropertyGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

model GuidePlace {
  id            String        @id @default(uuid())
  guideId       String
  category      PlaceCategory
  name          String
  description   String?
  imageUrl      String?
  address       String?
  distance      String?
  googleMapsUrl String?
  tags          String[]      @default([])
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  guide         PropertyGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

model MessageTemplate {
  id                 String               @id @default(uuid())
  propertyId         String?
  name               String
  slug               String?              @unique
  category           MessageCategory      @default(GENERAL)
  channelType        CommunicationChannel @default(WHATSAPP)
  subject            String?
  body               String
  isActive           Boolean              @default(true)
  isAutomatic        Boolean              @default(false)
  triggerType        MessageTrigger?
  triggerOffsetValue Int?                 @default(0)
  triggerOffsetUnit  TriggerUnit?         @default(DAYS)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  logs               MessageLog[]
  schedules          MessageSchedule[]
  property           Property?            @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model MessageLog {
  id              String               @id @default(uuid())
  templateId      String?
  guestId         String
  reservationId   String?
  propertyId      String
  channelType     CommunicationChannel
  recipient       String
  renderedSubject String?
  renderedBody    String
  status          MessageStatus        @default(SENT)
  scheduledFor    DateTime?
  sentAt          DateTime?
  errorMessage    String?
  createdBy       String?
  createdAt       DateTime             @default(now())
  guest           Guest                @relation(fields: [guestId], references: [id])
  reservation     Reservation?         @relation(fields: [reservationId], references: [id])
  template        MessageTemplate?     @relation(fields: [templateId], references: [id])

  @@index([guestId])
  @@index([reservationId])
}

model MessageSchedule {
  id            String          @id @default(uuid())
  templateId    String
  reservationId String
  guestId       String
  propertyId    String
  scheduledFor  DateTime
  status        ScheduleStatus  @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  template      MessageTemplate @relation(fields: [templateId], references: [id])

  @@unique([templateId, reservationId])
  @@index([scheduledFor])
}

enum UserRole {
  ADMIN
  USER
  CO_ADMIN
}

enum ReservationStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  CANCELLED_SYSTEM
  EXPIRED
}

enum CreditStatus {
  ACTIVE
  PARTIALLY_USED
  USED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  CREDIT_BALANCE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  EXPIRED
  CANCELLED
  FAILED
}

enum BlockedSource {
  AIRBNB
  BOOKING
  ADMIN
  DIRECT_RESERVATION
  MANUAL
  CHANNEX
}

enum WindowMode {
  MANUAL_RANGE
  ROLLING_FROM_TODAY
}

enum RuleType {
  WEEKEND_SURGE
  LAST_MINUTE
  EARLY_BIRD
  SEASONAL
}

enum Platform {
  AIRBNB
  BOOKING
  CHANNEX
}

enum SyncStatus {
  SUCCESS
  FAILED
}

enum SectionType {
  WELCOME
  HOST
  ABOUT_SPACE
  CHECK_IN
  CHECK_OUT
  HOUSE_RULES
  WIFI
  HOW_TO_GET
  HOUSE_MANUAL
  EMERGENCY
  TRANSPORT
  SPACE_TOUR
  TROUBLESHOOTING
  STAY_TIMELINE
  GUIDED_CHECKIN
  GUIDED_CHECKOUT
  OTHER
}

enum PlaceCategory {
  RESTAURANT
  CAFE
  SUPERMARKET
  MARKET
  PHARMACY
  PARK
  GYM_YOGA
  DELIVERY
  FOR_KIDS
  ATTRACTION
  BREAKFAST
  ROMANTIC
  FAMILY
  TO_GO
  OTHER
}

enum MessageCategory {
  PRE_CHECKIN
  CHECKIN
  DURING_STAY
  CHECKOUT
  POST_CHECKOUT
  MARKETING
  VIP
  BILLING
  REMINDER
  SUPPORT
  GENERAL
}

enum CommunicationChannel {
  WHATSAPP
  EMAIL
  BOTH
}

enum MessageTrigger {
  RESERVATION_CONFIRMED
  CHECKIN_DATE
  CHECKOUT_DATE
}

enum TriggerUnit {
  MINUTES
  HOURS
  DAYS
}

enum MessageStatus {
  DRAFT
  SCHEDULED
  READY
  SENT
  FAILED
  OPENED
  CLICKED
  CANCELLED
}

enum ScheduleStatus {
  PENDING
  PROCESSED
  CANCELLED
  FAILED
}
