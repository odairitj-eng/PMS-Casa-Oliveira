generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique @default("")

  // Fase 2: Configuração de Exibição Pública
  publicTitle      String?
  publicSubtitle   String?
  shortDescription String?  @db.Text
  fullDescription  String?  @db.Text
  hostName         String?
  propertyType     String?  @default("HOUSE")
  category         String?  @default("Casa")
  accommodationType String? @default("Espaço inteiro")

  // Capacidade e Estrutura
  maxGuests        Int      @default(4)
  bedrooms         Int      @default(2)
  beds             Int      @default(3)
  bathrooms        Int      @default(2)
  allowsPets       Boolean  @default(false)
  maxPets          Int      @default(0)

  // Estrutura do Prédio/Espaço
  buildingFloors   Int?     @default(1)
  floorNumber      Int?     @default(0)
  constructionYear Int?
  propertySize     Float?
  propertySizeUnit String?  @default("m²")

  // Localização
  street           String?
  streetNumber     String?
  neighborhood     String?
  city             String?
  state            String?
  postalCode       String?
  country          String?
  locationText     String?
  latitude         Float?
  longitude        Float?
  publicLatitude   Float?
  publicLongitude  Float?

  isActive         Boolean  @default(true)

  // Financeiro
  basePrice        Float
  cleaningFee      Float    @default(0)
  minimumNights    Int      @default(2)
  currency         String   @default("BRL")
  
  // Horários de Check-in/Out
  checkInStart     String?  @default("14:00")
  checkInEnd       String?  @default("22:00")
  checkOutEnd      String?  @default("11:00")

  // Wi-Fi
  wifiName         String?
  wifiPassword     String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channexId        String?  @unique
  reservations        Reservation[]
  blockedDates        BlockedDate[]
  nightlyOverrides    NightlyOverride[]
  pricingRules        PricingRule[]
  availabilityWindows AvailabilityWindow[]
  photos              PropertyPhoto[]
  amenities           PropertyAmenity[]
  rules               PropertyRule[]
  integrations        Integration[]
  syncLogs            SyncLog[]
  reservationLinks    ReservationLink[]
  
  cancellationPolicyId String?
  cancellationPolicy   CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id])
  
  guide                PropertyGuide?
  messageTemplates     MessageTemplate[]
}

model Guest {
  id                     String   @id @default(uuid())
  name                   String
  email                  String   @unique
  phone                  String
  status                 String   @default("REGULAR") // REGULAR, VIP, FIVE_STAR, INACTIVE, BLOCKED
  isVip                  Boolean  @default(false)
  isFiveStar             Boolean  @default(false)
  notes                  String?  @db.Text
  sourceChannel          String?  @default("DIRECT") // DIRECT, AIRBNB, BOOKING, WHATSAPP, MANUAL
  
  // Estatísticas Automáticas
  totalBookings          Int      @default(0)
  completedStays         Int      @default(0)
  totalRevenueGenerated  Float    @default(0)
  lastReservationAt      DateTime?
  lastStayAt             DateTime?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt @default(now())

  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id])
  reservations Reservation[]
  credits      ReservationCredit[]
  messageLogs  MessageLog[]
}

// Modelos Necessários para Auth.js (NextAuth)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
  guest         Guest?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
}

enum UserRole {
  ADMIN
  CO_ADMIN
  USER
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Reservation {
  id            String            @id @default(uuid())
  propertyId    String
  guestId       String
  checkIn       DateTime
  checkOut      DateTime
  status        ReservationStatus @default(PENDING_PAYMENT)
  totalAmount   Float
  nightlyRate   Float
  cleaningFee   Float
  totalNights   Int
  holdExpiresAt DateTime?
  accessToken   String            @unique @default(uuid())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id])
  guest        Guest         @relation(fields: [guestId], references: [id])
  payments     Payment[]
  blockedDates BlockedDate[]
  events       ReservationEvent[]
  
  numGuests    Int?          @default(1)
  occupants    ReservationOccupant[]

  // Rastreabilidade de Rebooking
  rebookedFromId String?     @unique
  rebookedFrom   Reservation? @relation("RebookingHistory", fields: [rebookedFromId], references: [id])
  rebookedTo     Reservation? @relation("RebookingHistory")

  rebookingHistory ReservationRebooking? @relation("OriginalReservation")
  replacementRef   ReservationRebooking? @relation("NewReservation")

  creditsGenerated ReservationCredit[]
  messageLogs      MessageLog[]

  @@index([propertyId])
  @@index([guestId])
}

enum ReservationStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  CANCELLED_SYSTEM
  EXPIRED
}

model CancellationPolicy {
  id                         String   @id @default(uuid())
  name                       String
  description                String?  @db.Text
  cancelFreeLimitHours       Int      @default(48)
  partialRefundPercentage    Float    @default(50)
  nonRefundableLimitHours    Int      @default(24)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  properties Property[]
}

model ReservationEvent {
  id            String   @id @default(uuid())
  reservationId String
  type          String   // CANCEL_REQUESTED, CANCELLED, REFUND_REQUESTED, REFUND_COMPLETED, etc
  userId        String?  // Quem realizou a ação (admin ou null se sistema/hóspede s/ login)
  reason        String?  @db.Text
  metadata      Json?    // Detalhes extras (ex: valores calculados)
  createdAt     DateTime @default(now())

  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model ReservationOccupant {
  id            String      @id @default(uuid())
  reservationId String
  name          String
  document      String?     // CPF ou Identidade
  isChild       Boolean     @default(false)
  
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model ReservationCredit {
  id                 String               @id @default(uuid())
  guestId            String
  propertyId         String?   // Se limitado a um imóvel
  sourceReservationId String?
  
  amountOriginal     Float
  amountAvailable    Float
  amountUsed         Float                @default(0)
  currency           String               @default("BRL")
  
  code               String               @unique // ex: CO-XXXX-YYYY
  reason             String?
  status             CreditStatus         @default(ACTIVE)
  
  expiresAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  guest             Guest                @relation(fields: [guestId], references: [id])
  sourceReservation Reservation?        @relation(fields: [sourceReservationId], references: [id])
  
  @@index([guestId])
  @@index([code])
}

enum CreditStatus {
  ACTIVE
  PARTIALLY_USED
  USED
  EXPIRED
  CANCELLED
}

model ReservationRebooking {
  id                     String   @id @default(uuid())
  originalReservationId  String   @unique
  newReservationId       String   @unique
  
  creditUsedAmount       Float    @default(0)
  additionalPaymentAmount Float   @default(0)
  reason                 String?  @db.Text
  
  createdBy              String?  // ID do admin
  createdAt              DateTime @default(now())

  originalReservation    Reservation @relation("OriginalReservation", fields: [originalReservationId], references: [id])
  newReservation         Reservation @relation("NewReservation", fields: [newReservationId], references: [id])
}

model Payment {
  id                   String        @id @default(uuid())
  reservationId        String
  gatewayTransactionId String?
  provider             String?       // ex: "MERCADO_PAGO"
  method               PaymentMethod
  status               PaymentStatus @default(PENDING)
  amount               Float
  externalId           String?       // ID na API externa
  expiresAt            DateTime?     // Para Pix ou boletos
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt @default(now())

  // Campos de Reembolso
  refundAmount         Float?
  refundStatus         String?       // PENDING, COMPLETED, FAILED
  refundProviderId     String?       // ID do refund no Mercado Pago
  refundedAt           DateTime?

  reservation Reservation @relation(fields: [reservationId], references: [id])
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  CREDIT_BALANCE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  EXPIRED
  CANCELLED
  FAILED
}

model BlockedDate {
  id            String        @id @default(uuid())
  propertyId    String
  date          DateTime
  source        BlockedSource
  reservationId String?
  reason        String?
  createdAt     DateTime      @default(now())

  property    Property     @relation(fields: [propertyId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@unique([propertyId, date])
  @@index([propertyId])
}

enum BlockedSource {
  AIRBNB
  BOOKING
  CHANNEX
  ADMIN
  DIRECT_RESERVATION
  MANUAL
}

enum WindowMode {
  MANUAL_RANGE
  ROLLING_FROM_TODAY
}

model AvailabilityWindow {
  id          String     @id @default(uuid())
  propertyId  String
  startDate   DateTime
  endDate     DateTime
  mode        WindowMode @default(MANUAL_RANGE)
  rollingDays Int?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, startDate, endDate])
}

model NightlyOverride {
  id            String   @id @default(uuid())
  propertyId    String
  date          DateTime
  price         Float
  minimumNights Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date])
  @@index([propertyId])
}

model PricingRule {
  id          String   @id @default(uuid())
  propertyId  String
  type        RuleType
  value       Float // Pode ser porcentagem (ex: 1.2 para +20%) ou valor fixo
  description String?
  minDays     Int?     // Para Early Bird e Last Minute dinâmico
  startDate   DateTime? // Para Sazonalidade
  endDate     DateTime? // Para Sazonalidade
  color       String?   // Para identificação visual no calendário
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

enum RuleType {
  WEEKEND_SURGE // Aumento automático de sexta a domingo
  LAST_MINUTE // Desconto para reservas em cima da hora
  EARLY_BIRD // Desconto para reservas antecipadas
  SEASONAL // Ajuste por temporada (ex: Verão/Inverno)
}

model Integration {
  id         String    @id @default(uuid())
  propertyId String
  platform   Platform
  icalUrl    String
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

enum Platform {
  AIRBNB
  BOOKING
  CHANNEX
}

model SyncLog {
  id           String     @id @default(uuid())
  propertyId   String?
  platform     Platform
  status       SyncStatus
  eventsAdded  Int        @default(0)
  errorMessage String?
  createdAt    DateTime   @default(now())

  property Property? @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

enum SyncStatus {
  SUCCESS
  FAILED
}

model SystemSettings {
  id                     String   @id @default("singleton")
  propertyId             String?
  mercadoPagoPublicKey   String?
  mercadoPagoAccessToken String?
  whatsappNumber         String?
  contactEmail           String?
  minNightsDefault       Int      @default(2)
  maxGuestsDefault       Int      @default(4)
  updatedAt              DateTime @updatedAt
}

model ReservationLink {
  id             String    @id @default(uuid())
  token          String    @unique
  propertyId     String?
  discount       Float?
  expiresAt      DateTime?
  preFilledDates String? // JSON string
  createdAt      DateTime  @default(now())

  property Property? @relation(fields: [propertyId], references: [id])
}

// ----------------------------------------------------
// FASE 2: CONTEÚDO DA PROPRIEDADE
// ----------------------------------------------------

model PropertyPhoto {
  id         String   @id @default(uuid())
  propertyId String
  imageUrl   String
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyAmenity {
  id          String   @id @default(uuid())
  propertyId  String
  amenityKey  String
  amenityName String
  iconName    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityKey])
  @@index([propertyId])
}

model PropertyRule {
  id         String   @id @default(uuid())
  propertyId String
  ruleText   String
  iconName   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model ProcessedEvent {
  id        String   @id
  provider  String
  createdAt DateTime @default(now())

  @@index([id, provider])
}

// ----------------------------------------------------
// FASE 4: GUEST EXPERIENCE GUIDE (HOUSE GUIDE)
// ----------------------------------------------------

model PropertyGuide {
  id         String   @id @default(uuid())
  propertyId String   @unique
  isActive   Boolean  @default(true)
  
  // Customizações de estilo (opcional para o futuro)
  accentColor String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sections   GuideSection[]
  places     GuidePlace[]
}

model GuideSection {
  id             String      @id @default(uuid())
  guideId        String
  type           SectionType
  title          String
  content        String?     @db.Text
  imageUrl       String?
  iconName       String?
  sortOrder      Int         @default(0)
  isActive       Boolean     @default(true)
  
  // Metadados específicos (ex: Wi-Fi credentials em JSON)
  config         Json?       
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  guide          PropertyGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

enum SectionType {
  WELCOME
  HOST
  ABOUT_SPACE
  CHECK_IN
  CHECK_OUT
  HOUSE_RULES
  WIFI
  HOW_TO_GET
  HOUSE_MANUAL
  EMERGENCY
  TRANSPORT
  SPACE_TOUR
  TROUBLESHOOTING
  STAY_TIMELINE
  GUIDED_CHECKIN
  GUIDED_CHECKOUT
  OTHER
}

model GuidePlace {
  id          String    @id @default(uuid())
  guideId     String
  category    PlaceCategory
  name        String
  description String?   @db.Text
  imageUrl    String?
  address     String?
  distance    String?   // ex: "500m", "5 min walk"
  googleMapsUrl String?
  tags        String[]  @default([]) // Tags de curadoria: "Favorito", "Perto", etc.
  
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guide       PropertyGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

enum PlaceCategory {
  RESTAURANT
  CAFE
  SUPERMARKET
  MARKET
  PHARMACY
  PARK
  GYM_YOGA
  DELIVERY
  FOR_KIDS
  ATTRACTION
  BREAKFAST
  ROMANTIC
  FAMILY
  TO_GO
  OTHER
}

// --- MÓDULO DE MENSAGENS E COMUNICAÇÃO ---

model MessageTemplate {
  id                  String   @id @default(uuid())
  propertyId          String?  // null = global template
  name                String
  slug                String?  @unique
  category            MessageCategory @default(GENERAL)
  channelType         CommunicationChannel @default(WHATSAPP)
  subject             String?  // Para e-mail
  body                String   @db.Text
  isActive            Boolean  @default(true)
  isAutomatic         Boolean  @default(false)
  
  // Lógica de Gatilho (Trigger)
  triggerType         MessageTrigger?
  triggerOffsetValue  Int?     @default(0)
  triggerOffsetUnit   TriggerUnit? @default(DAYS)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  property            Property? @relation(fields: [propertyId], references: [id])
  logs                MessageLog[]
  schedules           MessageSchedule[]

  @@index([propertyId])
}

model MessageLog {
  id              String   @id @default(uuid())
  templateId      String?
  guestId         String
  reservationId   String?
  propertyId      String
  channelType     CommunicationChannel
  recipient       String
  renderedSubject String?
  renderedBody    String   @db.Text
  status          MessageStatus @default(SENT)
  scheduledFor    DateTime?
  sentAt          DateTime?
  errorMessage    String?  @db.Text
  createdBy       String?  // ex: "SYSTEM" ou ID do Admin
  
  createdAt       DateTime @default(now())

  template        MessageTemplate? @relation(fields: [templateId], references: [id])
  guest           Guest            @relation(fields: [guestId], references: [id])
  reservation     Reservation?     @relation(fields: [reservationId], references: [id])

  @@index([guestId])
  @@index([reservationId])
}

model MessageSchedule {
  id              String   @id @default(uuid())
  templateId      String
  reservationId   String
  guestId         String
  propertyId      String
  scheduledFor    DateTime
  status          ScheduleStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  template        MessageTemplate @relation(fields: [templateId], references: [id])

  @@unique([templateId, reservationId]) // Evita agendar o mesmo template para a mesma reserva
  @@index([scheduledFor])
}

enum MessageCategory {
  PRE_CHECKIN
  CHECKIN
  DURING_STAY
  CHECKOUT
  POST_CHECKOUT
  MARKETING
  VIP
  BILLING
  REMINDER
  SUPPORT
  GENERAL
}

enum CommunicationChannel {
  WHATSAPP
  EMAIL
  BOTH
}

enum MessageTrigger {
  RESERVATION_CONFIRMED
  CHECKIN_DATE
  CHECKOUT_DATE
}

enum TriggerUnit {
  MINUTES
  HOURS
  DAYS
}

enum MessageStatus {
  DRAFT
  SCHEDULED
  READY
  SENT
  FAILED
  OPENED
  CLICKED
  CANCELLED
}

enum ScheduleStatus {
  PENDING
  PROCESSED
  CANCELLED
  FAILED
}
